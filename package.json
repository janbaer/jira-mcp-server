{
  "name": "jira-mcp-server",
  "version": "1.1.0",
  "description": "MCP server for creating Jira issues via REST API",
  "type": "module",
  "main": "dist/jira-mcp-server",
  "bin": {
    "jira-mcp-server": "./dist/jira-mcp-server"
  },
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/jira-mcp-server",
    "deploy": "bun run build && cp dist/jira-mcp-server ~/bin/jira-mcp-server",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bunx biome check src/",
    "lint:fix": "bunx biome check --fix src/",
    "mcp-inspect": "bun run build && npx @modelcontextprotocol/inspector ./dist/jira-mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "bun-types": "^1.3.6"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT"
}
