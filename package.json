{
  "name": "jira-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for creating Jira issues via REST API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jira-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bun": "bun build src/index.ts --outdir dist --target node",
    "start": "node dist/index.js",
    "start:bun": "bun run dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "dev:bun": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
